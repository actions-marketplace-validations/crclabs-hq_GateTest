# ============================================================================
# GateTest — environment variables
# ============================================================================
#
# Website-specific env vars also live in website/.env.example. This file
# captures repo-level integration secrets.
#

# ---- Gluecron async scan-result callback ----------------------------------
# When a Gluecron-originated scan completes (POST body carries
# `source: "gluecron"`), GateTest POSTs the result back to Gluecron here.
# Wire contract: Gluecron.com/GATETEST_HOOK.md
#
# Default callback URL: https://gluecron.com/api/hooks/gatetest
GLUECRON_CALLBACK_URL=

# Shared bearer token Gluecron presents on the receiver side
# (`Authorization: Bearer ${GLUECRON_CALLBACK_SECRET}`). Generate with:
#   openssl rand -hex 32
GLUECRON_CALLBACK_SECRET=

# ---- Signal Bus E1 — inbound push events + cron worker ---------------------
# HMAC secret for the inbound /api/events/push endpoint. Gluecron signs every
# POST body with HMAC-SHA256 keyed on this value and sends the result in the
# X-Signal-Signature header (format: `sha256=<hex>`). The secret MUST match
# the one Gluecron is configured with — rotate both sides together.
# Generate with: openssl rand -hex 32
GLUECRON_EMITTER_SECRET=

# Vercel cron validation header. The cron entry in vercel.json for
# /api/scan/worker/tick forwards this value; we also re-use it for the
# fire-and-forget inline kick from /api/events/push. If unset, the worker
# accepts calls lenient-mode for first-deploy / local-dev convenience.
CRON_SECRET=

# ---- Outbound: calling Gluecron ------------------------------------------
# GateTest calls Gluecron for repo meta, trees, blobs, statuses, PR
# comments, branch creation, file upserts, and PR opening. See
# src/core/gluecron-bridge.js and website/app/lib/gluecron-client.ts for
# the full wire surface.
#
# Base URL of the Gluecron deployment. Defaults to https://gluecron.com.
GLUECRON_BASE_URL=https://gluecron.com

# PAT (scope: repo). Format: glc_<64hex>. Generate at
# https://gluecron.com/settings/tokens — the token authenticates every
# outbound call we make to Gluecron.
GLUECRON_API_TOKEN=glc_

# ---- MCP server (bin/gatetest-mcp.mjs) ------------------------------------
# Override the hosted-API base. Useful if you self-host the gatetest.ai
# service or want to point the MCP server at a staging deploy.
# Default: https://www.gatetest.ai
GATETEST_HOSTED_BASE_URL=

# ---- Pre-push / CLI fast-mode flags --------------------------------------
# GATETEST_FAST=1 — skip potentially-slow modules (e.g. syntax → tsc
# --noEmit, which can take 30-60s per tsconfig on a real monorepo). Set
# automatically by the shipped pre-push hook so the local hook stays
# advisory + snappy. CI runs the full uncapped gate.
GATETEST_FAST=
# GATETEST_SKIP_TSC=1 — narrower equivalent that only skips the tsc
# step. Useful if you want every other check but tsc is too slow locally.
GATETEST_SKIP_TSC=
# GATETEST_TSC_TIMEOUT_MS — per-tsconfig timeout for tsc --noEmit.
# Default 60000ms (60s). Bump if you have a huge codebase + cold cache.
GATETEST_TSC_TIMEOUT_MS=
